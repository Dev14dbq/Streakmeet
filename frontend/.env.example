# Frontend env — copy to .env or .env.local

# --- API backends ---

# Legacy Node API (production Node-only, or explicit Node host when Rust is primary).
# Leave empty in Vite dev to use same-origin; set for Capacitor native builds.
# VITE_API_URL=https://api.example.com

# Node backend when Rust gateways are active (dev default http://127.0.0.1:3000).
# Required for streak remind, account delete fallback, Socket.IO notifications.
# VITE_NODE_API_URL=http://127.0.0.1:3000

# Rust api-gateway REST base. Empty → same-origin /api (Vite dev proxies to :8080).
# VITE_RUST_GATEWAY_URL=

# --- Connect sync (replaces Socket.IO for live cache patches) ---

# auto (probe :8080/:8081) | true | false — default auto
VITE_USE_SYNC_STREAM=auto

# Connect sync-gateway base (browser). Dev: Vite proxies /connect → :8081
# VITE_CONNECT_URL=/connect

# Dev only: false → Vite proxies /api to Node :3000 instead of Rust :8080
# VITE_DEV_RUST_PROXY=true

# --- OAuth / sign-in ---

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_IOS_CLIENT_ID=
VITE_APPLE_CLIENT_ID=

# --- Dev / QA ---

# Skip mobile-only gate on desktop browsers
# VITE_SKIP_MOBILE_GATE=true
