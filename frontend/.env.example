# Frontend env (copy to .env or .env.local)

# Legacy Node API — set full URL in production when not using Rust (e.g. https://api.example.com)
# VITE_API_URL=

# Connect sync: auto (probe Rust) | true | false — default auto uses Rust when gateways respond
VITE_USE_SYNC_STREAM=auto

# Connect sync-gateway base (browser). Dev: Vite proxies /connect → :8081
# VITE_CONNECT_URL=/connect

# Rust api-gateway base. Leave empty to use same-origin /api (Vite dev proxies to :8080)
# VITE_RUST_GATEWAY_URL=

# Dev only: false → Vite proxies /api to Node :3000 instead of Rust :8080
# VITE_DEV_RUST_PROXY=true

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_IOS_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
