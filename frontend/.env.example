# Frontend env (copy to .env)

# Legacy Node API (default Vite proxy /api → :3000)
# VITE_API_URL=

# Rust api-gateway (optional direct login testing)
# VITE_RUST_GATEWAY_URL=http://127.0.0.1:8080

# Connect sync stream (Phase 0 — off by default; socket.io remains primary)
VITE_USE_SYNC_STREAM=false
# VITE_CONNECT_URL=/connect

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_IOS_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
