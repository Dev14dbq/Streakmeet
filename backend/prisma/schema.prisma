generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String
  passwordHash  String
  nickname      String
  avatarUrl     String?
  qrCodeId      String    @unique @default(cuid())
  timezone      String    @default("UTC")
  gemsBalance   Int       @default(0)
  faceEnrolled  Boolean   @default(false)
  faceEmbedding Json?
  deletedAt     DateTime?
  isPublic      Boolean   @default(true)
  acceptedTermsVersion   Int @default(0)
  acceptedPrivacyVersion Int @default(0)
  sharingLocation Boolean  @default(false)
  lastLatitude    Float?
  lastLongitude   Float?
  lastLocationAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  friendshipsA    Friendship[]     @relation("FriendA")
  friendshipsB    Friendship[]     @relation("FriendB")
  streaksA        Streak[]         @relation("StreakUserA")
  streaksB        Streak[]         @relation("StreakUserB")
  gemTransactions GemTransaction[]
  meetProofs      MeetProof[]
  remoteSelfiesSent     RemoteSelfieRequest[] @relation("RemoteSelfieSender")
  remoteSelfiesReceived RemoteSelfieRequest[] @relation("RemoteSelfieReceiver")

  @@index([email])
  @@index([nickname])
  @@map("users")
}

model Friendship {
  id        String           @id @default(cuid())
  userAId   String
  userBId   String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  userA User @relation("FriendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@map("friendships")
}

model Streak {
  id          String   @id @default(cuid())
  userAId     String
  userBId     String
  count       Int      @default(0)
  lastMetDate String?  // формат YYYY-MM-DD
  timezone    String   @default("UTC")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userA      User        @relation("StreakUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB      User        @relation("StreakUserB", fields: [userBId], references: [id], onDelete: Cascade)
  streakDays StreakDay[]
  remoteSelfies RemoteSelfieRequest[]

  @@unique([userAId, userBId])
  @@map("streaks")
}

model StreakDay {
  id       String          @id @default(cuid())
  streakId String
  date     String          // формат YYYY-MM-DD
  status   StreakDayStatus @default(MET)

  streak     Streak      @relation(fields: [streakId], references: [id], onDelete: Cascade)
  meetProofs MeetProof[]

  @@unique([streakId, date])
  @@map("streak_days")
}

model MeetProof {
  id             String   @id @default(cuid())
  streakDayId    String
  uploadedById   String
  photoUrl       String
  photoHash      String
  latitude       Float?
  longitude      Float?
  livenessOk     Boolean  @default(false)
  facesDetected  Int      @default(0)
  matchScores    Json?
  createdAt      DateTime @default(now())

  streakDay  StreakDay @relation(fields: [streakDayId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation(fields: [uploadedById], references: [id])

  @@unique([streakDayId, photoHash])
  @@index([photoHash])
  @@map("meet_proofs")
}

model GemTransaction {
  id        String          @id @default(cuid())
  userId    String
  amount    Int
  reason    GemReason
  refId     String?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gem_transactions")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum StreakDayStatus {
  MET
  FROZEN
  MISSED
}

enum GemReason {
  MEET_PROOF
  STREAK_MILESTONE
  AD_REWARD
  FREEZE_SPEND
  RESCUE_FRIEND_SPEND
  GRACE_RESTORE_SPEND
  ADMIN_ADJUST
}

enum StreakNotificationKind {
  STREAK_1H
  STREAK_30M
  STREAK_BURNED
}

model StreakNotificationLog {
  id        String                 @id @default(cuid())
  userId    String
  streakId  String
  kind      StreakNotificationKind
  localDate String
  sentAt    DateTime               @default(now())

  @@unique([userId, streakId, kind, localDate])
  @@index([userId, localDate])
  @@map("streak_notification_logs")
}

model RemoteSelfieRequest {
  id             String   @id @default(cuid())
  streakId       String
  senderId       String
  receiverId     String
  senderPhotoUrl String
  status         RemoteSelfieStatus @default(PENDING)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  streak   Streak @relation(fields: [streakId], references: [id], onDelete: Cascade)
  sender   User   @relation("RemoteSelfieSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User   @relation("RemoteSelfieReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, status])
  @@map("remote_selfie_requests")
}

enum RemoteSelfieStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum LegalDocSlug {
  TERMS
  PRIVACY
}

model LegalDocument {
  id        String       @id @default(cuid())
  slug      LegalDocSlug @unique
  title     String
  version   Int          @default(1)
  content   String       @db.Text
  updatedAt DateTime     @updatedAt
  createdAt DateTime     @default(now())

  @@map("legal_documents")
}
